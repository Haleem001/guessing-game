<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title }) %>
  </head>
  <body class="lobby-page">
    <main class="lobby-shell">
      <section class="lobby-card">
        <h1>Create a game or join one</h1>
        <p class="lede">
          Generate a new room code to host, or enter a code from a friend to
          join.
        </p>

        <div class="lobby-options">
          <article class="option-card">
            <h2>Create</h2>
            <p>Generate a new room code and share it.</p>
          </article>
          <article class="option-card">
            <h2>Join</h2>
            <p>Enter a room code you already have.</p>
          </article>
        </div>

        <form id="join-form" class="join-form">
          <label for="name">Your Name</label>
          <input id="name" name="name" type="text" maxlength="24" required />

          <label for="roomId">Room ID</label>
          <div class="room-id-row">
            <input
              id="roomId"
              name="roomId"
              type="text"
              maxlength="24"
              required
            />
            <button id="generate-room-id" type="button" class="secondary-button">
              Generate New Code
            </button>
          </div>

          <button type="submit">Continue to Room</button>
        </form>
      </section>
    </main>
    <script src="/js/app.js"></script>
  </body>
</html>
